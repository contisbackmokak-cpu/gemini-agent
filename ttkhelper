-- noclip ve tween yardımcı fonksiyonları
local function toggleNoclip(state)
    if state then
        noclipConnection = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") and v.CanCollide then
                        v.CanCollide = false
                    end
                end
            end
        end)
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
    end
end

local function stopTween()
    if tweenInstance then
        tweenInstance:Cancel()
        tweenInstance = nil
    end
    toggleNoclip(false)
end

-- tween mantığı
local function tweenToLocation(targetCFrame, speed)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    
    -- önceki tween varsa durdur
    stopTween()
    
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local timeToReach = distance / speed
    
    local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)
    tweenInstance = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    
    toggleNoclip(true) -- duvarlara takılmamak için noclip açıyoruz
    tweenInstance:Play()
    
    tweenInstance.Completed:Connect(function()
        toggleNoclip(false)
        Fluent:Notify({
            Title = "Vardın!",
            Content = "Legendary Sword Dealer'a ulaştın.",
            Duration = 5
        })
    end)
end

-- satıcıyı bulma (derin tarama)
local function findDealer()
    local found = false
    dealerCFrame = nil
    
    print("[TTK Helper - Şeffaflık Modu] Tüm harita taranıyor... F9 Konsolunu kontrol edin.")
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            -- ismi içinde 'sword' veya 'dealer' geçen her şeyi konsola yazdır
            if string.find(string.lower(obj.Name), "sword") or string.find(string.lower(obj.Name), "dealer") then
                print("[TTK Helper] Şüpheli obje bulundu: '" .. obj.Name .. "' - Satıcı olup olmadığı kontrol ediliyor...")
            end

            -- kesin eşleşme kontrolü
            if obj.Name == "Legendary Sword Dealer" or obj.Name == "Sword Dealer" then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head") or obj.PrimaryPart
                if hrp then
                    dealerCFrame = hrp.CFrame
                    found = true
                    print("[TTK Helper] KESİN EŞLEŞME! Legendary Sword Dealer bulundu. Koordinat: " .. tostring(dealerCFrame.Position))
                    break
                end
            end
        end
    end
    
    if not found then
        print("[TTK Helper] Tarama tamamlandı. Sunucudaki on binlerce obje arasında 'Legendary Sword Dealer' KESİNLİKLE bulunamadı.")
    end
    
    return found
end

