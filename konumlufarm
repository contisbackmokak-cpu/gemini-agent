local function autoClick()
    task.spawn(function()
        while true do
            if UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                task.wait(0.2)
                continue
            end

            if (autoClickToggleState or autoFarmKills) then
                if config.controlMode then
                    -- YENİ: CONTROL MEYVESİ ÖZEL ATAK MODÜLÜ
                    local char = LocalPlayer.Character
                    if char then
                        local controlTool = char:FindFirstChild("Control-Control")
                        if not controlTool then
                            local backpackTool = LocalPlayer.Backpack:FindFirstChild("Control-Control")
                            if backpackTool then
                                char.Humanoid:EquipTool(backpackTool)
                                controlTool = backpackTool
                                task.wait(0.2)
                            end
                        end
                        
                        if controlTool then
                            local remote = controlTool:FindFirstChild("LeftClickRemote")
                            if remote then
                                pcall(function()
                                    -- Aşağı doğru (0, -0.9, 0.03) vektörü ile ateşle
                                    remote:FireServer(Vector3.new(0, -0.9, 0.03), 1)
                                end)
                            end
                        end
                                        end
                    task.wait(1 / 6) -- Control M1 Vurma Hızı
                    
                elseif config.yetiMode then
                    -- YENİ: YETİ MEYVESİ ÖZEL ATAK MODÜLÜ
                    local char = LocalPlayer.Character
                    if char then
                        local yetiTool = char:FindFirstChild("Yeti-Yeti")
                        if not yetiTool then
                            local backpackTool = LocalPlayer.Backpack:FindFirstChild("Yeti-Yeti")
                            if backpackTool then
                                char.Humanoid:EquipTool(backpackTool)
                                yetiTool = backpackTool
                                task.wait(0.2)
                            end
                        end
                        
                        if yetiTool then
                            local remote = yetiTool:FindFirstChild("LeftClickRemote")
                            if remote then
                                pcall(function()
                                    -- Verdiğin cobalt kodundaki Yeti M1 ateşleme olayı
                                    remote:FireServer(Vector3.new(-0.322111338377, 0, -0.94670188426971), 2)
                                end)
                            end
                        end
                    end
                    task.wait(1 / 6) -- Yeti M1 Vurma Hızı
                    
                elseif config.fastAttackModule then
                    minGamingFastAttack()
                    task.wait(0.05)
                else
                    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                    task.wait(0.05)
                end
            else
                task.wait(0.1) 
            end
        end
    end)
end
autoClick()

