local function safeTween(targetPos)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    isPlayerTweening = true
    hum:ChangeState(Enum.HumanoidStateType.Physics) 
    
    local dist = (hrp.Position - targetPos).Magnitude
    local tInfo = TweenInfo.new(dist / config.tweenSpeed, Enum.EasingStyle.Linear)
    local t = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(targetPos)})
    t:Play()
    t.Completed:Wait()
    
    hrp.Velocity = Vector3.zero
    hum:ChangeState(Enum.HumanoidStateType.Running)
    hrp.CFrame = CFrame.new(targetPos) 
    task.wait(0.2)
    isPlayerTweening = false
end

local function getAliveMobCount(targetName, playerPos, maxDist)
    local count = 0
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return 0 end

    for _, enemy in pairs(enemiesFolder:GetChildren()) do
        if targetName ~= "(hepsi)" and enemy.Name ~= targetName then
            continue
        end
        local eHrp = enemy:FindFirstChild("HumanoidRootPart")
        local eHum = enemy:FindFirstChild("Humanoid")
        if eHrp and eHum and eHum.Health > 0 then
            if (eHrp.Position - playerPos).Magnitude <= maxDist then
                count = count + 1
            end
        end
    end
    return count
end

local function startAutoFarm()
    task.spawn(function()
        while autoFarmEnabled do
            for i = 1, 5 do
                if not autoFarmEnabled then break end
                local stepName = _G.FarmDropdowns[i].Value
                if stepName and stepName ~= "(boş)" and config.positions[stepName] then
                    local posData = config.positions[stepName]
                    
                    safeTween(Vector3.new(posData.X, posData.Y, posData.Z))
                    
                    if not autoFarmEnabled then break end
                    
                    currentFarmTargetMob = posData.TargetMob or "(hepsi)"
                    task.wait(1)
                    
                    autoFarmKills = true 
                    task.wait(1.5) 
                    
                    local maxWait = 30 
                    local waited = 0
                    while autoFarmEnabled and waited < maxWait do
                        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local aliveCount = getAliveMobCount(currentFarmTargetMob, hrp.Position, config.bringDistance + 50)
                            if aliveCount <= 0 then
                                break 
                            end
                        end
                        task.wait(0.5)
                        waited = waited + 0.5
                    end
                    
                    autoFarmKills = false
                end
            end
            task.wait(1)
        end
    end)
end

