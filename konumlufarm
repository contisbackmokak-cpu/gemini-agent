local function saveConfig()
    if writefile then writefile(configFileName, HttpService:JSONEncode(config)) end
end

local function loadConfig()
    if isfile and isfile(configFileName) and readfile then
        local success, result = pcall(function() return HttpService:JSONDecode(readfile(configFileName)) end)
        if success and result then 
            for k, v in pairs(result) do config[k] = v end 
        end
    end
end
