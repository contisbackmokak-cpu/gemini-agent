-- MOB BRING (ÇEKME & SABİTLEME)
-- ==========================================
local function bringMobs()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return end

    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge)
        end
    end)

    for _, enemy in pairs(enemiesFolder:GetChildren()) do
        if currentFarmTargetMob ~= "(hepsi)" and enemy.Name ~= currentFarmTargetMob then
            continue
        end

        local eHrp = enemy:FindFirstChild("HumanoidRootPart")
        local eHum = enemy:FindFirstChild("Humanoid")
        if eHrp and eHum and eHum.Health > 0 then
            local dist = (hrp.Position - eHrp.Position).Magnitude

            if dist <= config.bringDistance then
                for _, part in pairs(enemy:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
                
                local animator = eHum:FindFirstChildOfClass("Animator")
                if animator then animator:Destroy() end
                
                eHum:ChangeState(11)
                
                -- YENİ: CONTROL VE YETİ MODU İÇİN 5 STUD ALTA, NORMAL İÇİN 12 STUD ÜSTE SABİTLEME
                if config.controlMode or config.yetiMode then
                    eHrp.CFrame = hrp.CFrame * CFrame.new(0, -7, 0)
                else
                    eHrp.CFrame = hrp.CFrame * CFrame.new(0, 12, 0)
                end
                
                eHrp.Velocity = Vector3.new(0, -0.01, 0) 
                eHrp.RotVelocity = Vector3.new(0, 0.01, 0)
                
                eHum.WalkSpeed = 0
                eHum.JumpPower = 0
                eHrp.Size = Vector3.new(10, 10, 10)
                
                pcall(function()
                    eHum:UnequipTools()
                    for _, item in pairs(enemy:GetChildren()) do
                        if item:IsA("Tool") then
                            item:Destroy()
                        end
                    end
                end)
            end
        end
    end
end

RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if bringToggleState or autoFarmKills then bringMobs() end
    
    if isPlayerTweening or autoFarmEnabled then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    if config.dashProtection and (autoClickToggleState or autoFarmKills) and not isPlayerTweening then
        if not lockedCFrame then
            lockedCFrame = hrp.CFrame
        end
        hrp.CFrame = lockedCFrame
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
    else
        lockedCFrame = nil
    end
end)

