local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local player = game.Players.LocalPlayer
local tween_service = game:GetService("TweenService")
local workspace = game:GetService("Workspace")
local core_gui = game:GetService("CoreGui")

local window = Fluent:CreateWindow({
    Title = "fruit",
    SubTitle = "nurullah kudurttu v3 (artik kastirmiyor)",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Theme = "Darker"
})

local tabs = {
    main = window:AddTab({ Title = "meyve avi", Icon = "apple" })
}

local esp_enabled = false
local tween_enabled = false
local tween_speed = 300
local aktif_tween = nil

local fruits_list = {}
local active_esps = {}

-- eski esp'leri temizle
local function clear_esps()
    for _, v in pairs(active_esps) do
        if v then v:Destroy() end
    end
    table.clear(active_esps)
end

-- esp cizdir
local function draw_esp(part, name)
    if not part then return end
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "fruit_esp_velet"
    billboard.Adornee = part
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.AlwaysOnTop = true
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, 0, 1, 0)
    text.BackgroundTransparency = 1
    text.Text = name .. " [FRUIT]"
    text.TextColor3 = Color3.fromRGB(0, 255, 0)
    text.TextStrokeTransparency = 0
    text.TextSize = 16
    text.Parent = billboard
    
    billboard.Parent = core_gui
    table.insert(active_esps, billboard)
end

-- esp'leri yenile
local function refresh_esps()
    clear_esps()
    if not esp_enabled then return end
    for tool, handle in pairs(fruits_list) do
        if handle and handle.Parent then
            draw_esp(handle, tool.Name)
        end
    end
end

tabs.main:AddToggle("esp_toggle", {Title = "fruit esp", Default = false}):OnChanged(function(state)
    esp_enabled = state
    refresh_esps()
end)

tabs.main:AddToggle("tween_toggle", {Title = "fruit oto tween (300 hiz)", Default = false}):OnChanged(function(state)
    tween_enabled = state
    if not state and aktif_tween then
        aktif_tween:Cancel()
        aktif_tween = nil
    end
end)

-- yeni meyve algilayici
local function add_fruit(v)
    if (v:IsA("Tool") or v:IsA("Model")) and string.find(string.lower(v.Name), "fruit") then
        local handle = v:FindFirstChild("Handle") or v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
        if handle then
            fruits_list[v] = handle
            refresh_esps()
        end
    end
end

-- silinen meyveyi listeden at
local function remove_fruit(v)
    if fruits_list[v] then
        fruits_list[v] = nil
        refresh_esps()
    end
end

-- workspace'i yormadan sadece degisiklikleri dinle
workspace.DescendantAdded:Connect(add_fruit)
workspace.DescendantRemoving:Connect(remove_fruit)

-- ilk acilista bi kere tara ki mapteki hazir meyveleri kacirmayalim
for _, v in pairs(workspace:GetDescendants()) do
    add_fruit(v)
end

-- tween dongusu (sadece gercekten lazimsa calisiyor)
task.spawn(function()
    while task.wait(0.1) do
        if tween_enabled then
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local root = char.HumanoidRootPart
                local target_handle = nil
                
                -- listedeki ilk meyveyi sec
                for _, handle in pairs(fruits_list) do
                    if handle and handle.Parent then
                        target_handle = handle
                        break
                    end
                end
                
                if target_handle then
                    local dist = (root.Position - target_handle.Position).Magnitude
                    local time = dist / tween_speed
                    
                    local tween_info = TweenInfo.new(time, Enum.EasingStyle.Linear)
                    aktif_tween = tween_service:Create(root, tween_info, {CFrame = target_handle.CFrame})
                    aktif_tween:Play()
                    
                    aktif_tween.Completed:Wait()
                    task.wait(0.2)
                end
            end
        end
    end
end)
