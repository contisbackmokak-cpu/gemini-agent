local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "meyve dızlayıcı v565",
    SubTitle = "nurullah'ın tam otomatik intikamı",
    TabWidth = 160,
    Size = UDim2.fromOffset(480, 320),
    Acrylic = false,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "dızlama", Icon = "apple" }),
    AutoStore = Window:AddTab({ Title = "oto sakla", Icon = "box" })
}

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local dizzingEnabled = false
local autoStoreEnabled = false
local attemptedFruits = {} -- crash yememek için aynı meyveyi bir kere deneyip bıraktığımız liste

Tabs.Main:AddToggle("DizToggle", {
    Title = "otomatik meyve vakumla",
    Default = false,
    Callback = function(state)
        dizzingEnabled = state
        if state then
            Fluent:Notify({Title = "aktif", Content = "haritadaki sahipsiz meyveler kafana yağacak ameka.", Duration = 3})
        else
            Fluent:Notify({Title = "pasif", Content = "vakum kapandı.", Duration = 3})
        end
    end
})

Tabs.AutoStore:AddToggle("StoreToggle", {
    Title = "oto sakla (elde tutup cukkalama)",
    Default = false,
    Callback = function(state)
        autoStoreEnabled = state
        if state then
            Fluent:Notify({Title = "aktif", Content = "gelen meyveler saniyesinde depoya atılacak.", Duration = 3})
        end
    end
})

-- 1. AŞAMA: MEYVEYİ VAKUMLAMA DÖNGÜSÜ
RunService.RenderStepped:Connect(function()
    if not dizzingEnabled then return end
    
    pcall(function()
        if sethiddenproperty then
            sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge)
        end
    end)

    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Tool") and string.find(obj.Name, "Fruit") then
            local handle = obj:FindFirstChild("Handle")
            if handle then
                handle.CanCollide = false
                handle.CFrame = char.HumanoidRootPart.CFrame
            end
        end
    end
end)

-- 2. AŞAMA: ELDE TUTUP SAKLAMA (TÜM MEYVELER İÇİN DİNAMİK İSİM BAZLI)
task.spawn(function()
    while task.wait(0.5) do
        if not autoStoreEnabled then continue end
        
        local commF = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
        commF = commF and commF:FindFirstChild("CommF_")
        if not commF then continue end
        
        local function storeFruit(tool)
            if tool:IsA("Tool") and (string.find(tool.Name, "Fruit") or tool.ToolTip == "Demon Fruit") then
                
                -- crash önleme: bu tool objesini daha önce denediysek pas geç
                if attemptedFruits[tool] then return end 

                pcall(function()
                    local char = LocalPlayer.Character
                    local hum = char and char:FindFirstChild("Humanoid")
                    
                    -- çantadaysa karakterin eline aldırıyoruz (servera göstermek için)
                    if hum and tool.Parent == LocalPlayer.Backpack then
                        hum:EquipTool(tool)
                        task.wait(0.5) -- eline alması ve serverın onaylaması için bekle
                    end
                    
                    -- artık elimizde, cobalt metodunu mermiliyoruz
                    if tool.Parent == char then
                        -- dumduz "Rocket", "Spin", "Mammoth" vb. ismini aliyoruz
                        local baseName = string.gsub(tool.Name, " Fruit", "") 
                        local storeName = baseName
                        
                        -- eğer isimde tire (-) yoksa, blox fruits serverının istediği gibi ikiliyoruz
                        -- örnek: "Rocket" ise "Rocket-Rocket" olur. zaten "Spider-Spider" ise dokunmaz.
                        if not string.find(baseName, "-") then
                            storeName = baseName .. "-" .. baseName
                        end
                        
                        -- cobalt'ın ifşa ettiği o kusursuz, tek atan remote!
                        commF:InvokeServer("StoreFruit", storeName, tool)
                        
                        -- spamı ve crashi engellemek için bu meyveyi kara listeye al
                        attemptedFruits[tool] = true 
                    end
                end)
            end
        end

        pcall(function()
            -- önce çantayı tara
            for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                storeFruit(tool)
            end
            -- sonra zatwn eline aldığın varsa ona çullan
            if LocalPlayer.Character then
                for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
                    storeFruit(tool)
                end
            end
        end)
    end
end)

Window:SelectTab(1)
