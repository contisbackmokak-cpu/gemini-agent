local function cacheTyrantEyes()
    cachedEyes = {}
    local TikiOutpost = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("TikiOutpost")
    if not TikiOutpost then return end
    
    for _, obj in pairs(TikiOutpost:GetDescendants()) do
        if obj:IsA("BasePart") and string.find(string.lower(obj.Name), "eye") then
            local isChar = false
            local p = obj.Parent
            while p and p ~= workspace do
                if p:FindFirstChildOfClass("Humanoid") then isChar = true break end
                p = p.Parent
            end
            
            if not isChar then
                table.insert(cachedEyes, obj)
            end
        end
    end
end

local function GetGlowingEyeCount()
    local count = 0
    local total = #cachedEyes
    
    if total == 0 then return 0, 0 end
    
    for _, eye in ipairs(cachedEyes) do
        if eye.Transparency < 1 then 
            count = count + 1 
        end
    end
    return count, total
end

local function holdGodhumanX()
    setStatus("tyrant çağrılıyor! godhuman x şarjlanıyor (mutlak beton mod)...")
    isSummoningTyrant = true -- RunService'e karakteri mühürlemesi emrini veriyoruz
    
    pcall(function()
        VIM:SendKeyEvent(true, Enum.KeyCode.X, false, game)
        for i=1, 50 do
            if not autoTyrantMode then break end
            
            local enemies = workspace:FindFirstChild("Enemies")
            if enemies and enemies:FindFirstChild(EXACT_BOSS_NAME) then
                task.wait(0.3) 
                break
            end
            
            task.wait(0.1)
        end
        VIM:SendKeyEvent(false, Enum.KeyCode.X, false, game)
        
        setStatus("x atıldı! fps toparlanıyor, patlama efektleri bekleniyor (1.5sn)...")
        task.wait(1.5) -- Patlama (dash) efekti bitene kadar kilitli kalmasını sağlıyor
    end)
    
    isSummoningTyrant = false -- Kilidi aç
end

local function startTyrantRoutine()
    task.spawn(function()
        local patrolIdx = 1
        cacheTyrantEyes()
        
        while autoTyrantMode do
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            
            if not hrp or not hum or hum.Health <= 0 then 
                setStatus("öldün lan koçum, 4 saniye dirilme bekleniyor...")
                autoFarmKills = false
                autoClickToggleState = false
                isSummoningTyrant = false
                lockedCFrame = nil
                broughtMobs = {}
                task.wait(4) 
                continue 
            end

            if not autoTyrantMode then break end

            local enemies = workspace:FindFirstChild("Enemies")
            if not enemies then task.wait(1) continue end

            local boss = enemies:FindFirstChild(EXACT_BOSS_NAME)
            if boss then
                local bossHrp = boss:FindFirstChild("HumanoidRootPart")
                local bossHum = boss:FindFirstChild("Humanoid")
                
                if bossHrp and bossHum and bossHum.Health > 0 then
                    if bossHrp.Position.Magnitude < 10 then 
                        setStatus("boss doğdu ama kordinatları bozuk (oyun laglı), bekleniyor...")
                        task.wait(0.5)
                        continue
                    end
                    
                    setStatus("YARGI DAĞITILIYOR: " .. EXACT_BOSS_NAME .. " içinden geçiliyor!")
                    broughtMobs = {} 
                    equipFarmWeapon()
                    
                    local yOffset = 15
                    if config.selectedWeapon == "Control-Control" then
                        yOffset = 5
                    end
                    local targetCFrame = bossHrp.CFrame * CFrame.new(0, yOffset, 0)
                    
                    if (hrp.Position - targetCFrame.Position).Magnitude > 20 then 
                        safeTween(targetCFrame.Position) 
                    end
                    
                    if not autoTyrantMode then break end
                    
                    hrp.CFrame = targetCFrame
                    lockedCFrame = targetCFrame 
                    
                    currentFarmTargetMob = EXACT_BOSS_NAME 
                    autoFarmKills = true
                    autoClickToggleState = true
                    task.wait(0.1)
                    continue
                end
            end

            if currentFarmTargetMob == EXACT_BOSS_NAME then
                currentFarmTargetMob = "(hepsi)"
            end

            local glowing, total = GetGlowingEyeCount()
            if total > 0 and glowing == total then
                setStatus("gözler kan çanağı! tyrant çağırma noktasına gidiliyor...")
                autoFarmKills = false
                autoClickToggleState = false
                broughtMobs = {}
                
                local summonPos = Vector3.new(-16267.45, 153.04, 1392.07)
                
                if (hrp.Position - summonPos).Magnitude > 10 then safeTween(summonPos) end
                if not autoTyrantMode then break end
                
                hrp.CFrame = CFrame.new(summonPos)
                lockedCFrame = hrp.CFrame
                
                equipGodhuman()
                holdGodhumanX()
                
                for i=1, 12 do
                    if not autoTyrantMode then break end
                    if enemies:FindFirstChild(EXACT_BOSS_NAME) then break end
                    setStatus("boss aranıyor... (bekleme: " .. i .. "/12 sn)")
                    task.wait(1)
                end
                continue
            end

            local closestMob = nil
            local closestDist = math.huge
            
            pcall(function() if sethiddenproperty then sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge) end end)

            for _, enemy in pairs(enemies:GetChildren()) do
                if tikiMobsDict[enemy.Name] then
                    local eHrp = enemy:FindFirstChild("HumanoidRootPart")
                    local eHum = enemy:FindFirstChild("Humanoid")
                    if eHrp and eHum and eHum.Health > 0 then
                        local dist = (hrp.Position - eHrp.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closestMob = enemy
                        end
                    end
                end
            end

            if closestMob then
                local mainHrp = closestMob:FindFirstChild("HumanoidRootPart")
                if mainHrp then
                    setStatus("seyyar vakum devrede: " .. closestMob.Name .. " ve saz arkadaşları kesiliyor...")
                    
                    mainHrp.Anchored = false 
                    broughtMobs = {} 
                    
                    table.insert(broughtMobs, {
                        hrp = mainHrp,
                        hum = closestMob:FindFirstChild("Humanoid"),
                        targetCFrame = mainHrp.CFrame
                    })
                    
                    local yOffset = 15
                    if config.selectedWeapon == "Control-Control" then
                        yOffset = 5
                    end
                    local targetCFrame = mainHrp.CFrame * CFrame.new(0, yOffset, 0)
                    
                    if (hrp.Position - targetCFrame.Position).Magnitude > 20 then safeTween(targetCFrame.Position) end
                    if not autoTyrantMode then break end
                    
                    hrp.CFrame = targetCFrame
                    lockedCFrame = targetCFrame 
                    
                    equipFarmWeapon()
                    autoFarmKills = true
                    autoClickToggleState = true

                    for _, enemy in pairs(enemies:GetChildren()) do
                        if enemy ~= closestMob and tikiMobsDict[enemy.Name] then
                            local eHrp = enemy:FindFirstChild("HumanoidRootPart")
                            local eHum = enemy:FindFirstChild("Humanoid")
                            if eHrp and eHum and eHum.Health > 0 then
                                local distToMain = (eHrp.Position - mainHrp.Position).Magnitude
                                if distToMain <= 60 then
                                    eHrp.Anchored = false 
                                    for _, part in pairs(enemy:GetDescendants()) do
                                        if part:IsA("BasePart") then part.CanCollide = false end
                                    end
                                    local anim = eHum:FindFirstChildOfClass("Animator")
                                    if anim then anim:Destroy() end
                                    
                                    eHrp.Size = Vector3.new(10, 10, 10)
                                    
                                    pcall(function()
                                        eHum:UnequipTools()
                                        for _, item in pairs(enemy:GetChildren()) do
                                            if item:IsA("Tool") then item:Destroy() end
                                        end
                                    end)

                                    table.insert(broughtMobs, {
                                        hrp = eHrp,
                                        hum = eHum,
                                        targetCFrame = mainHrp.CFrame
                                    })
                                end
                            end
                        end
                    end
                end
            else
                setStatus("haritada canlı tiki kalmadı, havada devriye atılıyor ameka...")
                autoFarmKills = false
                autoClickToggleState = false
                broughtMobs = {}
                local spawnPos = tikiSpawns[patrolIdx]
                safeTween(spawnPos + Vector3.new(0, 50, 0))
                patrolIdx = patrolIdx + 1
                if patrolIdx > #tikiSpawns then patrolIdx = 1 end
                
                for i=1, 15 do
                    if not autoTyrantMode then break end
                    task.wait(0.1)
                end
            end
            
            task.wait(0.1)
        end

        setStatus("sistem kapalı, dinleniyoruz.")
        autoFarmKills = false
        autoClickToggleState = false
        isSummoningTyrant = false
        lockedCFrame = nil
        broughtMobs = {}
    end)
end

local function autoClick()
    task.spawn(function()
        while true do
            if UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                task.wait(0.2)
                continue
            end
            
            if autoClickToggleState or autoFarmKills then
                if config.selectedWeapon == "Control-Control" then
                    local char = LocalPlayer.Character
                    if char then
                        local controlTool = char:FindFirstChild("Control-Control")
                        if controlTool and not isPlayerTweening then
                            local remote = controlTool:FindFirstChild("LeftClickRemote")
                            if remote then
                                pcall(function()
                                    remote:FireServer(Vector3.new(0, -0.9, 0.03), 1)
                                end)
                            end
                        end
                    end
                    task.wait(1 / 6)
                elseif config.fastAttackModule then
                    minGamingFastAttack()
                    task.wait(0.05)
                else
                    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    task.wait(0.05)
                    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                    task.wait(0.05)
                end
            else
                task.wait(0.1) 
            end
        end
    end)
end
autoClick()

RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if isPlayerTweening or autoTyrantMode then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    -- YENİ EKLENEN: Godhuman X Çağırma aşamasında mutlak kilit (Beton Mod)
    if isSummoningTyrant then
        if not lockedCFrame then lockedCFrame = hrp.CFrame end
        hrp.CFrame = lockedCFrame
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
    elseif config.dashProtection and (autoClickToggleState or autoFarmKills) and not isPlayerTweening and not hrp.Anchored then
        if not lockedCFrame then lockedCFrame = hrp.CFrame end
        hrp.CFrame = lockedCFrame
        hrp.Velocity = Vector3.zero
        hrp.RotVelocity = Vector3.zero
    else
        lockedCFrame = nil
    end

    -- Mob Vakum Kontrolcüsü (NetworkOwner Desync Engelleme ve Anti-Knockback)
    if autoFarmKills and broughtMobs and #broughtMobs > 0 then
        for i = #broughtMobs, 1, -1 do
            local mobData = broughtMobs[i]
            if mobData.hrp and mobData.hum and mobData.hum.Health > 0 and mobData.hrp.Parent then
                
                for _, v in pairs(mobData.hrp:GetChildren()) do
                    if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") or v:IsA("BodyForce") or v:IsA("LinearVelocity") or v:IsA("VectorForce") then
                        v:Destroy()
                    end
                end

                mobData.hrp.AssemblyLinearVelocity = Vector3.zero
                mobData.hrp.AssemblyAngularVelocity = Vector3.zero
                mobData.hum.PlatformStand = true

                local dist = (mobData.hrp.Position - mobData.targetCFrame.Position).Magnitude
                if dist > 40 then
                    table.remove(broughtMobs, i)
                    continue
                end

                mobData.hrp.CFrame = mobData.targetCFrame
            else
                table.remove(broughtMobs, i)
            end
        end
    end
end)

local function getWeaponList()
    local w = {}
    for _, v in pairs(LocalPlayer.Backpack:GetChildren()) do
        if v:IsA("Tool") then table.insert(w, v.Name) end
    end
    local char = LocalPlayer.Character
    if char then
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Tool") then table.insert(w, v.Name) end
        end
    end
    if #w == 0 then return {"Godhuman"} end
    return w
end

