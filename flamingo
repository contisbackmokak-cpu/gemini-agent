-- 3. HIZ HİLESİ (JITTER FİXLENMİŞ VE WALK SPEED KORUNMUŞ SİSTEM) KISMI
---------------------------------------------------------
local speedEnabled = false
local speedValue = 50 
local defaultWalkSpeed = 16 

Tabs.Speed:AddToggle("SpeedToggle", {
    Title = "Hız Hilesi (Kusursuz Mod)",
    Description = "Yürürken normal hız, Flamingodayken titreşimsiz uçuş.",
    Default = false,
    Callback = function(Value)
        speedEnabled = Value
        if not Value and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = defaultWalkSpeed
        end
    end
})

Tabs.Speed:AddSlider("SpeedSlider", {
    Title = "Hız Değeri",
    Description = "Yürüme hızı ve Flamingonun ek uçuş hızı.",
    Default = 50,
    Min = 16,
    Max = 250,
    Rounding = 0,
    Callback = function(Value)
        speedValue = Value
    end
})

-- 1. NORMAL YÜRÜME İÇİN (Oyunun hızı sıfırlamasını engellemek için RenderStepped ZORUNLU)
RunService.RenderStepped:Connect(function()
    if speedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local char = LocalPlayer.Character
        local isFlamingo = char:FindFirstChild("Flamingo") and char.Flamingo:IsA("Accessory")
        
        -- Eğer Flamingoda DEĞİLSEK WalkSpeed'i uygula (Eskisi gibi sorunsuz çalışması için)
        if not isFlamingo then
            char.Humanoid.WalkSpeed = speedValue
        end
    end
end)

-- 2. FLAMİNGO UÇUŞU İÇİN (Fizik motoru ve kameranın titrememesi için Heartbeat ZORUNLU)
RunService.Heartbeat:Connect(function(deltaTime)
    if speedEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local char = LocalPlayer.Character
        local isFlamingo = char:FindFirstChild("Flamingo") and char.Flamingo:IsA("Accessory")
        
        -- Eğer Flamingodaysak 3D titremesiz uçuşu uygula
        if isFlamingo then
            local cam = workspace.CurrentCamera
            local moveVec = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + cam.CFrame.RightVector end
            
            if moveVec.Magnitude > 0 then
                moveVec = moveVec.Unit
                char:PivotTo(char:GetPivot() + (moveVec * (speedValue * deltaTime)))
            end
        end
    end
end)

Fluent:Notify({
    Title = "Son Fix Uygulandı!",
    Content = "WalkSpeed eskisi gibi çalışıyor, Flamingo da titremiyor. Kusursuz!",
    Duration = 5
})
