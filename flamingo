-- 1. EŞYA BYPASS (MAIN) KISMI
---------------------------------------------------------
local bypassEnabled = false

Tabs.Main:AddToggle("FlamingoBypassToggle", {
    Title = "Enable 1-4 Keys Bypass",
    Description = "Flamingodayken yetenekleri zorla almanı sağlar.",
    Default = false,
    Callback = function(Value)
        bypassEnabled = Value
    end
})

local keyMapping = {
    [Enum.KeyCode.One] = "Melee",       
    [Enum.KeyCode.Two] = "Blox Fruit",  
    [Enum.KeyCode.Three] = "Sword",     
    [Enum.KeyCode.Four] = "Gun"         
}

local function forceEquipTool(tool)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("Humanoid") then return end
    char.Humanoid:UnequipTools() 
    task.wait(0.01)
    char.Humanoid:EquipTool(tool)
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
    if not bypassEnabled then return end
    if UserInputService:GetFocusedTextBox() then return end

    local targetType = keyMapping[input.KeyCode]
    if targetType then
        local targetTool = nil
        for _, t in pairs(LocalPlayer.Backpack:GetChildren()) do
            if t:IsA("Tool") and t.ToolTip == targetType then
                targetTool = t
                break
            end
        end
        if not targetTool and LocalPlayer.Character then
            for _, t in pairs(LocalPlayer.Character:GetChildren()) do
                if t:IsA("Tool") and t.ToolTip == targetType then
                    targetTool = t
                    break
                end
            end
        end
        if targetTool then
            if targetTool.Parent == LocalPlayer.Character then
                LocalPlayer.Character.Humanoid:UnequipTools()
            else
                forceEquipTool(targetTool)
            end
        end
    end
end)

