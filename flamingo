-- 2. LOVE FRUIT (KUSURSUZ OTOMATİK) KISMI
---------------------------------------------------------
local bestieTPEnabled = false
local hasNotifiedBestie = false

Tabs.LoveFruit:AddToggle("BestieToggle", {
    Title = "Bestie Auto-Tween (Love V)",
    Description = "Klonunu (Blank Buddy) otomatik bulur ve düşmana uçurur.",
    Default = false,
    Callback = function(Value)
        bestieTPEnabled = Value
        if not Value then
            hasNotifiedBestie = false
        end
    end
})

local function getBesties()
    local besties = {}
    local char = LocalPlayer.Character
    
    local function checkModel(v)
        if v:IsA("Model") and v ~= char and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            if Players:GetPlayerFromCharacter(v) then return end
            
            local name = string.lower(v.Name)
            if string.find(name, "blank buddy") or string.find(name, "bestie") or name == string.lower(LocalPlayer.Name) then
                if not v.HumanoidRootPart.Anchored then
                    table.insert(besties, v)
                end
            end
        end
    end

    for _, v in pairs(workspace:GetChildren()) do checkModel(v) end
    if workspace:FindFirstChild("Characters") then
        for _, v in pairs(workspace.Characters:GetChildren()) do checkModel(v) end
    end
    if workspace:FindFirstChild("Enemies") then
        for _, v in pairs(workspace.Enemies:GetChildren()) do checkModel(v) end
    end
    
    return besties
end

local function getNearestEnemy(position, bestiesList)
    local nearestEnemy = nil
    local shortestDistance = math.huge
    
    if workspace:FindFirstChild("Enemies") then
        for _, enemy in pairs(workspace.Enemies:GetChildren()) do
            if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 and enemy:FindFirstChild("HumanoidRootPart") then
                
                local isOurClone = false
                for _, b in pairs(bestiesList) do
                    if b == enemy then
                        isOurClone = true
                        break
                    end
                end
                
                if not isOurClone then
                    local dist = (enemy.HumanoidRootPart.Position - position).Magnitude
                    if dist < shortestDistance then
                        shortestDistance = dist
                        nearestEnemy = enemy
                    end
                end
                
            end
        end
    end
    return nearestEnemy
end

task.spawn(function()
    while task.wait(0.1) do
        if bestieTPEnabled then
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                
                local currentBesties = getBesties()
                local nearest = getNearestEnemy(char.HumanoidRootPart.Position, currentBesties)
                
                if nearest and nearest:FindFirstChild("HumanoidRootPart") and #currentBesties > 0 then
                    
                    if not hasNotifiedBestie then
                        hasNotifiedBestie = true
                        Fluent:Notify({
                            Title = "Klon Uçuşa Geçti!",
                            Content = "Otomatik yakalama başarılı, P tuşuna gerek kalmadı!",
                            Duration = 3
                        })
                    end
                    
                    for _, bestie in pairs(currentBesties) do
                        local bestieHRP = bestie:FindFirstChild("HumanoidRootPart")
                        if bestieHRP then
                            local targetCFrame = nearest.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2.5)
                            local distance = (bestieHRP.Position - targetCFrame.Position).Magnitude
                            local speed = 300
                            local timeToReach = distance / speed
                            
                            if timeToReach < 0.05 then
                                timeToReach = 0.05
                            end
                            
                            local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear)
                            local tween = TweenService:Create(bestieHRP, tweenInfo, {CFrame = targetCFrame})
                            tween:Play()
                        end
                    end
                end
            end
        end
    end
end)

