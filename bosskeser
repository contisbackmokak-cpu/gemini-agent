-- 1000 Stud Yakındaki Özgün NPC İsimlerini Bul
local function yakindaki_npcleri_bul()
    local npc_isimleri = {}
    local char = oyuncu.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if not hrp then return npc_isimleri end

    local function isim_ekle(npc)
        if npc:FindFirstChild("Humanoid") and npc.Humanoid.Health > 0 and npc:FindFirstChild("HumanoidRootPart") then
            local uzaklik = (hrp.Position - npc.HumanoidRootPart.Position).Magnitude
            if uzaklik <= 1000 then
                -- Aynı isimde birden fazla NPC varsa listeye bir kez eklesin
                if not table.find(npc_isimleri, npc.Name) then
                    table.insert(npc_isimleri, npc.Name)
                end
            end
        end
    end

    for _, klasor_adi in pairs({"Enemies", "NPCs", "Mob", "Monsters"}) do
        local klasor = workspace:FindFirstChild(klasor_adi)
        if klasor then
            for _, npc in pairs(klasor:GetChildren()) do
                isim_ekle(npc)
            end
        end
    end
    
    if #npc_isimleri == 0 then
        for _, obj in pairs(workspace:GetChildren()) do
            if obj:IsA("Model") and obj ~= char then
                isim_ekle(obj)
            end
        end
    end
    
    return npc_isimleri
end

