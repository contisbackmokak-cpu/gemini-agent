local ada_isimleri = {}
for isim, _ in pairs(adalar) do
    table.insert(ada_isimleri, isim)
end
table.sort(ada_isimleri)

local islandDropdown = tabs.main:AddDropdown("IslandSelector", {
    Title = "gitmek istediğin adayı seç",
    Values = ada_isimleri,
    CurrentValue = nil,
    Callback = function(value)
        secilen_ada_cframe = adalar[value]
        fluent:Notify({
            Title = "hedef kilitlendi",
            Content = value .. " adası rota olarak ayarlandı koçum.",
            Duration = 3
        })
    end
})

tabs.main:AddToggle("flyToggle", {
    Title = "300 hızla adaya fişekle",
    Description = "seçtiğin adaya doğru x, y, z ekseninde uçmaya başlarsın.",
    Default = false,
    Callback = function(state)
        uciyor_muyuz = state
        
        if uciyor_muyuz then
            if not secilen_ada_cframe then
                fluent:Notify({ Title = "hata", Content = "önce dropdown'dan bir ada seç lan!", Duration = 3 })
                return
            end
            
            fluent:Notify({ Title = "yolculuk başladı", Content = "300 hızla yardırıyoruz, sıkı tutun.", Duration = 3 })
            
            baglanti = runService.Heartbeat:Connect(function(dt)
                local char = localPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") and secilen_ada_cframe then
                    local hrp = char.HumanoidRootPart
                    
                    -- haritaya gömülme diye tam koordinatın 150 stud yukarısını hedef alıyoruz
                    local hedef_pozisyon = secilen_ada_cframe.Position + Vector3.new(0, 150, 0)
                    local gitme_yonu = (hedef_pozisyon - hrp.Position).Unit
                    
                    -- düşüş hızı sıfırlama titremeyi engeller
                    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    
                    -- 300 hızla uçuş
                    hrp.CFrame = hrp.CFrame + (gitme_yonu * (300 * dt))
                    
                    -- varış kontrolü
                    if (hedef_pozisyon - hrp.Position).Magnitude < 30 then
                        uciyor_muyuz = false
                        if baglanti then baglanti:Disconnect() end
                        fluent:Notify({ Title = "vardık", Content = "adaya ulaştın reis, toggle kapandı.", Duration = 3 })
                    end
                end
            end)
        else
            if baglanti then
                baglanti:Disconnect()
                baglanti = nil
            end
        end
    end
})

