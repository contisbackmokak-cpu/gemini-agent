-- getCurrentMelee is defined globally near the top

local function autoStyleTask()
    task.spawn(function()
        while task.wait(3) do
            if config.autoBuyStyles and not isStoringFruit then
                local meleeTool = getCurrentMelee()
                if not meleeTool then continue end
                
                local currentName = meleeTool.Name
                -- Mastery seviyesini Tool içindeki Level değerinden çekiyoruz
                local currentMastery = meleeTool:FindFirstChild("Level") and meleeTool.Level.Value or 0
                local data = LocalPlayer:FindFirstChild("Data")
                if not data or not data:FindFirstChild("Beli") then continue end
                
                local myBeli = data.Beli.Value
                local nextStyle = nil
                
                -- İsimleri hem yeni (arayüz) hem eski (kod) adlarıyla kontrol ediyoruz
                local isCombat = string.find(currentName, "Combat")
                local isDarkStep = string.find(currentName, "Dark Step") or string.find(currentName, "Black")
                local isElectric = string.find(currentName, "Electric") or string.find(currentName, "Electro")
                
                if isCombat then 
                    nextStyle = styleData[1]
                elseif isDarkStep and currentMastery >= config.targetMastery then 
                    nextStyle = styleData[2]
                elseif isElectric and currentMastery >= config.targetMastery then 
                    nextStyle = styleData[3] 
                end
                
                if nextStyle then
                    if myBeli >= nextStyle.cost then
                        Fluent:Notify({Title = "565 ruhu", Content = nextStyle.name .. " stili için yola çıkıldı!", Duration = 3})
                        
                        local wasAutoFarm = autoLevelFarmEnabled
                        if wasAutoFarm then 
                            autoLevelFarmEnabled = false 
                            autoFarmKills = false
                            isMovingToQuest = true
                            task.wait(1) 
                        end
                        
                        if nextStyle.wp then
                            safeTween(nextStyle.wp.Position)
                            task.wait(1)
                        end
                        
                        safeTween(nextStyle.pos.Position)
                        task.wait(0.5)
                        
                        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(nextStyle.remote)
                        task.wait(1)
                        
                        if wasAutoFarm then
                            isMovingToQuest = false
                            autoLevelFarmEnabled = true
                            startAutoLevelFarm()
                        end
                    end
                end
            end
        end
    end)
end
autoStyleTask()

