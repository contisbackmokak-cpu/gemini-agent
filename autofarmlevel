local function checkQuestStatus(targetMobName)
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui then return false end
    local main = pGui:FindFirstChild("Main")
    if not main then return false end
    local questUI = main:FindFirstChild("Quest")
    
    if questUI and questUI.Visible then
        local container = questUI:FindFirstChild("Container")
        local questTitle = container and container:FindFirstChild("QuestTitle")
        local titleLabel = questTitle and questTitle:FindFirstChild("Title")
        
        if titleLabel and titleLabel.Text then
            if string.find(titleLabel.Text, targetMobName) or (targetMobName == "Fajita" and string.find(titleLabel.Text, "Orbitus")) or (targetMobName == "Orbitus" and string.find(titleLabel.Text, "Fajita")) then
                return true
            else
                pcall(function() game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("AbandonQuest") end)
                return false
            end
        end
        return false 
    end
    return false
end

local bypassedBosses = {}
local bossQuestRetry = 0
local isDoingAlternativeQuest = false
local lastQuestStatus = false

local function startAutoLevelFarm()
    task.spawn(function()
        while autoLevelFarmEnabled do
            if isStoringFruit then
                autoFarmKills = false
                task.wait(0.2)
                continue
            end
            local Mon, LevelQuest, NameQuest, NameMon, CFrameQuest, CFrameMon
            local isBoss = false
            local spawnedBoss = nil
            
            local normalMon, normalLevelQuest, normalNameQuest, normalNameMon, normalCFrameQuest, normalCFrameMon = getLevelData()
            if config.autoBoss then
                spawnedBoss = getSpawnedBoss(normalCFrameQuest)
            end
            
            -- Eğer Boss bulunduysa normal dataları boss verileriyle eziyoruz
            if spawnedBoss then
                NameMon = spawnedBoss[1]
                NameQuest = spawnedBoss[2]
                LevelQuest = spawnedBoss[3]
                CFrameQuest = spawnedBoss[4]
                CFrameMon = spawnedBoss[6]
                Mon = NameMon
                isBoss = true
            else
                Mon, LevelQuest, NameQuest, NameMon, CFrameQuest, CFrameMon = normalMon, normalLevelQuest, normalNameQuest, normalNameMon, normalCFrameQuest, normalCFrameMon
                
                if config.doubleQuest and LevelQuest > 1 then
                    if isDoingAlternativeQuest then
                        local foundAlt = false
                        local playerLevel = LocalPlayer.Data.Level.Value
                        for lvl = playerLevel, 1, -1 do
                            local aMon, aLQ, aNQ, aNMon, aCQ, aCMon = getLevelData(lvl)
                            if aNQ == NameQuest and aLQ < LevelQuest then
                                Mon, LevelQuest, NameQuest, NameMon, CFrameQuest, CFrameMon = aMon, aLQ, aNQ, aNMon, aCQ, aCMon
                                foundAlt = true
                                break
                            elseif aNQ ~= NameQuest then
                                break
                            end
                        end
                        if not foundAlt then
                            isDoingAlternativeQuest = false
                        end
                    end
                else
                    isDoingAlternativeQuest = false
                end
            end
            
            if Mon then
                currentFarmTargetMob = NameMon
                local hasQuest = checkQuestStatus(NameMon) 

                -- Boss için görev yoksa (görev adı nil veya boşsa) veya çok fazla denediysek bypass et!
                if isBoss and (not NameQuest or NameQuest == "" or bypassedBosses[NameMon]) then
                    hasQuest = true
                end

                if lastQuestStatus == true and hasQuest == false then
                    isDoingAlternativeQuest = not isDoingAlternativeQuest
                end
                lastQuestStatus = hasQuest

                if not hasQuest then
                    isMovingToQuest = true
                    autoFarmKills = false
                    safeTween(CFrameQuest.Position)
                    local char = LocalPlayer.Character
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        if (char.HumanoidRootPart.Position - CFrameQuest.Position).Magnitude < 20 then
                            pcall(function()
                                game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", NameQuest, LevelQuest)
                            end)
                            task.wait(1)
                            
                            -- Boss görevi denemesi fail olursa bugda kalmaması için akıllı bypass
                            if isBoss then
                                bossQuestRetry = bossQuestRetry + 1
                                if bossQuestRetry >= 4 then
                                    bypassedBosses[NameMon] = true 
                                    bossQuestRetry = 0
                                end
                            else
                                bossQuestRetry = 0
                            end
                        end
                    end
                else
                    bossQuestRetry = 0
                    isMovingToQuest = false
                    
                    if config.bringMobs then
                        if isBoss then
                            local targetMobHRP = getClosestMob(NameMon)
                            if targetMobHRP then
                                local safePos = targetMobHRP.Position + Vector3.new(0, 25, 0)
                                safeTween(safePos)
                                autoFarmKills = true
                            else
                                if CFrameMon then
                                    safeTween(CFrameMon.Position + Vector3.new(0, 25, 0))
                                end
                                autoFarmKills = false
                            end
                        else
                            if CFrameMon then
                                local safePos = CFrameMon.Position + Vector3.new(0, 25, 0)
                                safeTween(safePos)
                            end
                            autoFarmKills = true
                        end
                    else
                        local targetMobHRP = getClosestMob(NameMon)
                        if targetMobHRP then
                            local safePos = targetMobHRP.Position + Vector3.new(0, 25, 0)
                            safeTween(safePos)
                            autoFarmKills = true
                        else
                            if isBoss then
                                if CFrameMon then
                                    safeTween(CFrameMon.Position + Vector3.new(0, 25, 0))
                                end
                                autoFarmKills = false
                            else
                                if CFrameMon then
                                    local safePos = CFrameMon.Position + Vector3.new(0, 25, 0)
                                    safeTween(safePos)
                                end
                                autoFarmKills = false 
                            end
                        end
                    end
                end
            end
            task.wait(0.5)
        end
        autoFarmKills = false
        isMovingToQuest = false 
        currentFarmTargetMob = "(hepsi)"
    end)
end

