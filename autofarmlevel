local mobSpawnPositions = setmetatable({}, {__mode = "k"})

local function getMobSpawnPos(enemy)
    if not enemy or not enemy:IsDescendantOf(workspace) then return nil end
    local eHrp = enemy:FindFirstChild("HumanoidRootPart")
    if not eHrp then return nil end
    
    if not mobSpawnPositions[enemy] then
        mobSpawnPositions[enemy] = eHrp.Position
    end
    return mobSpawnPositions[enemy]
end

local function getCurrentMelee()
    if not LocalPlayer.Character then return nil end
    local knownNames = {"Combat", "Black", "Dark Step", "Electro", "Electric", "Fishman", "Water Kung Fu"}
    
    local function isMelee(tool)
        if not tool:IsA("Tool") then return false end
        if tool.ToolTip == "Melee" then return true end
        for _, n in ipairs(knownNames) do
            if string.find(tool.Name, n) then return true end
        end
        return false
    end

    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        if isMelee(tool) then return tool end
    end
    for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
        if isMelee(tool) then return tool end
    end
    return nil
end

local function getEquippedTool(char)
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then return v end
    end
    return nil
end

local function equipMelee()
    if isStoringFruit then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    local current = getEquippedTool(char)
    if current then
        local knownNames = {"Combat", "Black", "Dark Step", "Electro", "Electric", "Fishman", "Water Kung Fu"}
        local isMelee = current.ToolTip == "Melee"
        if not isMelee then
            for _, n in ipairs(knownNames) do
                if string.find(current.Name, n) then
                    isMelee = true
                    break
                end
            end
        end
        if isMelee then return end
    end
    
    local melee = getCurrentMelee()
    if melee and melee.Parent == LocalPlayer.Backpack then
        hum:EquipTool(melee)
    end
end

local function findEnemiesInRange(targetList, enemies)
    local char = LocalPlayer.Character
    if not char then return nil end
    local pos = char:GetPivot().Position
    local mainTarget = nil
    
    for _, enemy in ipairs(enemies) do
        if currentFarmTargetMob ~= "(hepsi)" and enemy.Name ~= currentFarmTargetMob and not (currentFarmTargetMob == "Fajita" and enemy.Name == "Orbitus") and not (currentFarmTargetMob == "Orbitus" and enemy.Name == "Fajita") then
            continue
        end
        
        if enemy:FindFirstChildOfClass("Humanoid") and enemy.Humanoid.Health > 0 then
            local targetPart = enemy:FindFirstChild("Head") or enemy:FindFirstChild("HumanoidRootPart")
            if targetPart and ((pos - targetPart.Position).Magnitude <= 75) then
                table.insert(targetList, {enemy, targetPart})
                mainTarget = targetPart
            end
        end
    end
    return mainTarget
end

local function minGamingFastAttack()
    if isStoringFruit then return end
    local char = LocalPlayer.Character
    if not char then return end
    
    equipMelee()
    
    local targetList = {}
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return end
    
    local mainTarget = findEnemiesInRange(targetList, enemies:GetChildren())
    if not mainTarget then return end
    
    local equippedTool = getEquippedTool(char)
    if not equippedTool then return end
    
    pcall(function()
        local repStorage = game:GetService("ReplicatedStorage")
        local regAttack = repStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterAttack")
        local regHit = repStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterHit")
        
        if #targetList > 0 then
            regAttack:FireServer(1e-9) 
            regHit:FireServer(mainTarget, targetList) 
        end
    end)
end

