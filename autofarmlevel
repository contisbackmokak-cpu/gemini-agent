local activeBossCache = nil
local activeBossLastSeen = 0

local function getSpawnedBoss()
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return nil end

    if activeBossCache then
        local foundAlive = false
        local foundDead = false
        for _, enemy in ipairs(enemiesFolder:GetChildren()) do
            if enemy.Name == activeBossCache[1] then
                local hum = enemy:FindFirstChild("Humanoid")
                if hum then
                    if hum.Health > 0 then
                        foundAlive = true
                        activeBossLastSeen = os.time()
                        break
                    else
                        foundDead = true
                    end
                end
            end
        end
        
        if foundAlive then
            return activeBossCache
        elseif foundDead then
            activeBossCache = nil
        elseif (os.time() - activeBossLastSeen < 15) then
            return activeBossCache
        else
            activeBossCache = nil
        end
    end

    local myLevel = LocalPlayer:FindFirstChild("Data") and LocalPlayer.Data.Level.Value or 1

    for i = #BossData, 1, -1 do
        local boss = BossData[i]
        local reqLevel = boss[5] or 0
        
        if myLevel >= reqLevel then
            for _, enemy in ipairs(enemiesFolder:GetChildren()) do
                if enemy.Name == boss[1] then
                    local hum = enemy:FindFirstChild("Humanoid")
                    if hum and hum.Health > 0 then
                        activeBossCache = boss
                        activeBossLastSeen = os.time()
                        return boss
                    end
                end
            end
        end
    end
    return nil
end

