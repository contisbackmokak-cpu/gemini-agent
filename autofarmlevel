local function getEquippedTool(char)
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then return v end
    end
    return nil
end

local function findEnemiesInRange(targetList, enemies)
    local char = LocalPlayer.Character
    if not char then return nil end
    local pos = char:GetPivot().Position
    local mainTarget = nil
    
    for _, enemy in ipairs(enemies) do
        if currentFarmTargetMob ~= "(hepsi)" and enemy.Name ~= currentFarmTargetMob then
            continue
        end
        
        if enemy:FindFirstChildOfClass("Humanoid") and enemy.Humanoid.Health > 0 then
            local targetPart = enemy:FindFirstChild("Head") or enemy:FindFirstChild("HumanoidRootPart")
            if targetPart and ((pos - targetPart.Position).Magnitude <= 75) then
                table.insert(targetList, {enemy, targetPart})
                mainTarget = targetPart
            end
        end
    end
    return mainTarget
end

local function minGamingFastAttack()
    local char = LocalPlayer.Character
    if not char then return end
    
    local tool = LocalPlayer.Backpack:FindFirstChildOfClass("Tool")
    if tool and not char:FindFirstChildOfClass("Tool") then
        char.Humanoid:EquipTool(tool)
    end
    
    local targetList = {}
    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return end
    
    local mainTarget = findEnemiesInRange(targetList, enemies:GetChildren())
    if not mainTarget then return end
    
    local equippedTool = getEquippedTool(char)
    if not equippedTool then return end
    
    pcall(function()
        local repStorage = game:GetService("ReplicatedStorage")
        local regAttack = repStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterAttack")
        local regHit = repStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterHit")
        
        if #targetList > 0 then
            regAttack:FireServer(1e-9) 
            regHit:FireServer(mainTarget, targetList) 
        end
    end)
end

