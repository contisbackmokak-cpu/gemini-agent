local function autoFruitTask()
    task.spawn(function()
        while task.wait(0.5) do
            -- Eşya taşırken ya da adalar arası uçarken (tweening) storelamayı ertele
            if isPlayerTweening then continue end
            if not config.autoStoreFruit and not config.autoRollFruit then continue end
            
            local currentTime = os.time()
            local commF = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
            commF = commF and commF:FindFirstChild("CommF_")
            if not commF then continue end
            
            local function storeFruit(tool)
                if tool:IsA("Tool") and (string.find(tool.Name, "Fruit") or tool.ToolTip == "Demon Fruit") then
                    if attemptedFruits[tool] then return end 

                    isStoringFruit = true
                    pcall(function()
                        local char = LocalPlayer.Character
                        local hum = char and char:FindFirstChild("Humanoid")
                        
                        -- çantadaysa karakterin eline aldırıyoruz (servera göstermek için)
                        if hum and tool.Parent == LocalPlayer.Backpack then
                            hum:EquipTool(tool)
                            task.wait(0.5) -- eline alması ve serverın onaylaması için bekle
                        end
                        
                        -- artık elimizde, cobalt metodunu mermiliyoruz
                        if tool.Parent == char then
                            -- dumduz "Rocket", "Spin", "Mammoth" vb. ismini aliyoruz
                            local baseName = string.gsub(tool.Name, " Fruit", "") 
                            local storeName = baseName
                            
                            -- eğer isimde tire (-) yoksa, blox fruits serverının istediği gibi ikiliyoruz
                            -- örnek: "Rocket" ise "Rocket-Rocket" olur. zaten "Spider-Spider" ise dokunmaz.
                            if not string.find(baseName, "-") then
                                storeName = baseName .. "-" .. baseName
                            end
                            
                            -- cobalt'ın ifşa ettiği o kusursuz, tek atan remote!
                            commF:InvokeServer("StoreFruit", storeName, tool)
                            task.wait(0.5) -- server cevabı için bekle
                            
                            -- softlock önleme: eğer meyve hala elimizde kaldıysa (depo dolu demektir), backpack'e geri sok
                            if tool.Parent == char and hum then
                                hum:UnequipTools()
                            end
                            
                            -- spamı ve crashi engellemek için bu meyveyi kara listeye al
                            attemptedFruits[tool] = true 
                        end
                    end)
                    isStoringFruit = false
                end
            end

            if config.autoRollFruit then
                if currentTime - lastFruitRoll >= 7200 then
                    pcall(function()
                        commF:InvokeServer("Cousin", "Buy")
                        task.wait(1.5)
                        
                        local foundFruit = false
                        local function checkAndStore(tool)
                            if tool:IsA("Tool") and (string.find(tool.Name, "Fruit") or tool.ToolTip == "Demon Fruit") then
                                foundFruit = true
                                if config.autoStoreFruit then
                                    storeFruit(tool)
                                end
                            end
                        end
                        for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                            checkAndStore(tool)
                        end
                        if LocalPlayer.Character then
                            for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
                                checkAndStore(tool)
                            end
                        end
                        
                        -- Always attempt to close gacha UI after rolling
                        closeFruitGachaUI()

                        if foundFruit then
                            lastFruitRoll = currentTime
                            Fluent:Notify({Title = "Gacha", Content = "Meyve başarıyla çevrildi ve saklandı!", Duration = 5})
                        else
                            -- Enforce 5-minute cooldown before retrying
                            lastFruitRoll = currentTime - 7200 + 300
                        end
                    end)
                end
            end
            
            if config.autoStoreFruit then
                pcall(function()
                    -- önce çantayı tara
                    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                        storeFruit(tool)
                    end
                    -- sonra zaten eline aldığın varsa ona çullan
                    if LocalPlayer.Character then
                        for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
                            storeFruit(tool)
                        end
                    end
                end)
            end
        end
    end)
end
