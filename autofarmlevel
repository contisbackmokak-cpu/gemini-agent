-- AUTO SECOND SEA (SEA 2'YE GEÇİŞ) ALGORİTMASI
-- ==========================================
local isAutoSecondSeaRunning = false

local function startAutoSecondSea()
    if isAutoSecondSeaRunning then return end
    isAutoSecondSeaRunning = true

    task.spawn(function()
        local player = game.Players.LocalPlayer
        local data = player:FindFirstChild("Data")
        local rs = game:GetService("ReplicatedStorage")
        local commF = rs:WaitForChild("Remotes"):WaitForChild("CommF_")
        local char = player.Character or player.CharacterAdded:Wait()

        if not data or data.Level.Value < 700 then
            Fluent:Notify({
                Title = "Yetersiz Level", 
                Content = "Levelin " .. (data and data.Level.Value or "bilinmiyor") .. ". Sea 2 için en az 700 olmalısın!", 
                Duration = 5
            })
            isAutoSecondSeaRunning = false
            return
        end

        Fluent:Notify({Title = "Sea 2 Geçişi Başladı", Content = "Görevler otomatik yapılıyor...", Duration = 3})

        local detectiveCFrame = CFrame.new(4851.78, 5.69, 720.99)
        local doorHitboxCFrame = CFrame.new(1348.74, 37.39, -1324.74)
        local bossRoomCFrame = CFrame.new(1415, 37, -1321)
        local captainCFrame = CFrame.new(-1166.13, 7.69, 1729.61)

        local hasKey = player.Backpack:FindFirstChild("Key") or char:FindFirstChild("Key")
        
        if not hasKey then
            Fluent:Notify({Title = "Aşama 1", Content = "Military Detective'e gidiliyor...", Duration = 3})
            safeTween(detectiveCFrame.Position)
            task.wait(1.5)
            commF:InvokeServer("MilitaryDetective") 
            task.wait(2)
            hasKey = player.Backpack:FindFirstChild("Key") or char:FindFirstChild("Key")
            if not hasKey then
                Fluent:Notify({Title = "Bilgi", Content = "Anahtar alınamadı veya görevi zaten yaptın.", Duration = 4})
            end
        end

        Fluent:Notify({Title = "Aşama 2", Content = "Buz köyüne gidiliyor...", Duration = 3})
        safeTween(doorHitboxCFrame.Position)
        task.wait(1)

        local keyItem = player.Backpack:FindFirstChild("Key")
        if keyItem then
            char.Humanoid:EquipTool(keyItem)
            task.wait(1)
        end

        if char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = doorHitboxCFrame
            task.wait(1.5)
        end

        Fluent:Notify({Title = "Aşama 3", Content = "Ice Admiral aranıyor...", Duration = 3})
        safeTween(bossRoomCFrame.Position)
        task.wait(1)

        local bossKilled = false
        while not bossKilled and isAutoSecondSeaRunning do
            local boss = getClosestMob("Ice Admiral")
            if boss then
                Fluent:Notify({Title = "Savaş Başladı", Content = "Ice Admiral kesiliyor...", Duration = 3})
                currentFarmTargetMob = "Ice Admiral"
                autoFarmKills = true
                
                repeat 
                    task.wait(1)
                    boss = getClosestMob("Ice Admiral")
                until not boss or boss.Parent == nil or not isAutoSecondSeaRunning
                
                autoFarmKills = false
                currentFarmTargetMob = "(hepsi)"
                bossKilled = true
                Fluent:Notify({Title = "Başarılı", Content = "Ice Admiral başarıyla gebertildi!", Duration = 3})
                task.wait(3)
            else
                Fluent:Notify({Title = "Bekleniyor", Content = "Ice Admiral'ın spawn olması bekleniyor...", Duration = 4})
                task.wait(10)
            end
        end

        if bossKilled then
            Fluent:Notify({Title = "Aşama 4", Content = "Dedektife geri dönülüyor...", Duration = 3})
            safeTween(detectiveCFrame.Position)
            task.wait(1.5)
            commF:InvokeServer("MilitaryDetective")
            task.wait(3)
        end

        Fluent:Notify({Title = "Aşama 5", Content = "Experienced Captain'e gidiliyor...", Duration = 3})
        safeTween(captainCFrame.Position)
        task.wait(1.5)

        Fluent:Notify({Title = "Hoşçakal", Content = "Second Sea'ye ışınlanıyorsun!", Duration = 5})
        commF:InvokeServer("TravelDressrosa")
        
        isAutoSecondSeaRunning = false
    end)
end

