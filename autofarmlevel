local function autoStatsTask()
    task.spawn(function()
        while task.wait(0.2) do
            if config.autoStats then
                pcall(function()
                    local data = LocalPlayer:FindFirstChild("Data")
                    if not data then return end
                    
                    local points = data:FindFirstChild("Points")
                    if points and points.Value > 0 then
                        local stats = data:FindFirstChild("Stats")
                        local meleeLvl = stats.Melee.Level.Value
                        local defLvl = stats.Defense.Level.Value
                        local commF = game:GetService("ReplicatedStorage").Remotes.CommF_
                        
                        local pointsVal = points.Value
                        if meleeLvl < 2800 or defLvl < 2800 then
                            if meleeLvl <= defLvl then
                                local needed = 2800 - meleeLvl
                                local toAdd = math.min(pointsVal, needed)
                                commF:InvokeServer("AddPoint", "Melee", toAdd)
                            else
                                local needed = 2800 - defLvl
                                local toAdd = math.min(pointsVal, needed)
                                commF:InvokeServer("AddPoint", "Defense", toAdd)
                            end
                        else
                            commF:InvokeServer("AddPoint", "Demon Fruit", pointsVal)
                        end
                    end
                end)
            end
        end
    end)
end
