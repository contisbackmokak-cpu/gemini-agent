local function safeTween(targetPos)
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    -- 1. Underwater City'e (Fishman) Gidiş Döngüsü
    -- Başarıyla içeri girene kadar (X pozisyonumuz 50000'i geçene kadar) girdabı dener
    while targetPos.X > 50000 and hrp.Position.X < 50000 do
        local whirlpoolPos = Vector3.new(4053, 2, -1815)
        local wpDist = (hrp.Position - whirlpoolPos).Magnitude
        
        if wpDist > 15 then
            -- Girdaba 15 metreden uzaksak oraya tween at
            isPlayerTweening = true
            hum:ChangeState(Enum.HumanoidStateType.Physics)
            local tInfo = TweenInfo.new(wpDist / config.tweenSpeed, Enum.EasingStyle.Linear)
            local t = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(whirlpoolPos)})
            t:Play()
            t.Completed:Wait()
        else
            -- Girdaba vardığımızda tween'i kapatıp karakteri normal fiziğe sok (Oyun geri atmasın diye)
            isPlayerTweening = false
            hrp.Velocity = Vector3.zero
            hum:ChangeState(Enum.HumanoidStateType.Running)
            hrp.CFrame = CFrame.new(whirlpoolPos)
            task.wait(1.5) -- Işınlanmak için bekle
        end
    end

    -- 2. Underwater City'den Çıkış Döngüsü
    -- Başarıyla haritaya dönene kadar (X pozisyonumuz 50000'in altına düşene kadar) çıkış portalını dener
    while targetPos.X < 50000 and hrp.Position.X > 50000 do
        local exitPortalPos = Vector3.new(61163, 11, 1819)
        local exitDist = (hrp.Position - exitPortalPos).Magnitude
        
        if exitDist > 15 then
            isPlayerTweening = true
            hum:ChangeState(Enum.HumanoidStateType.Physics)
            local tInfo = TweenInfo.new(exitDist / config.tweenSpeed, Enum.EasingStyle.Linear)
            local t = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(exitPortalPos)})
            t:Play()
            t.Completed:Wait()
        else
            isPlayerTweening = false
            hrp.Velocity = Vector3.zero
            hum:ChangeState(Enum.HumanoidStateType.Running)
            hrp.CFrame = CFrame.new(exitPortalPos)
            task.wait(1.5)
        end
    end

    -- Normal hedefe asıl tween işlemini başlat (İçerideysen moba, dışarıdaysan moba)
    local dist = (hrp.Position - targetPos).Magnitude
    if dist < 5 then 
        hrp.CFrame = CFrame.new(targetPos)
        return 
    end

    isPlayerTweening = true
    hum:ChangeState(Enum.HumanoidStateType.Physics) 
    local tInfo = TweenInfo.new(dist / config.tweenSpeed, Enum.EasingStyle.Linear)
    local t = TweenService:Create(hrp, tInfo, {CFrame = CFrame.new(targetPos)})
    t:Play()
    t.Completed:Wait()
    
    hrp.Velocity = Vector3.zero
    hum:ChangeState(Enum.HumanoidStateType.Running)
    hrp.CFrame = CFrame.new(targetPos) 
    task.wait(0.1)
    isPlayerTweening = false
end

