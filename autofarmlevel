local function bringMobsLogic()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    if not enemiesFolder then return end

    pcall(function()
        if sethiddenproperty then sethiddenproperty(LocalPlayer, "SimulationRadius", math.huge) end
    end)

    local useV1 = config.bringMobs
    local useV2 = config.bringMobsV2
    local radius = 0
    
    if useV1 then radius = tonumber(config.bringDistance) or 320 
    elseif useV2 then radius = tonumber(config.bringDistanceV2) or 150 
    else radius = 75 end

    for _, enemy in pairs(enemiesFolder:GetChildren()) do
        if currentFarmTargetMob ~= "(hepsi)" and enemy.Name ~= currentFarmTargetMob and not (currentFarmTargetMob == "Fajita" and enemy.Name == "Orbitus") and not (currentFarmTargetMob == "Orbitus" and enemy.Name == "Fajita") then continue end

        local eHrp = enemy:FindFirstChild("HumanoidRootPart")
        local eHum = enemy:FindFirstChild("Humanoid")
        
        if eHrp and eHum and eHum.Health > 0 then
            local spawnPos = getMobSpawnPos(enemy)
            if spawnPos then
                local distFromSpawnToPlayer = (hrp.Position - spawnPos).Magnitude
                if distFromSpawnToPlayer > 135 then
                    continue
                end
            end

            local dist = (hrp.Position - eHrp.Position).Magnitude
            if dist <= radius then
                for _, part in pairs(enemy:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
                
                local animator = eHum:FindFirstChildOfClass("Animator")
                if animator then animator:Destroy() end
                
                eHum:ChangeState(11)
                eHum.WalkSpeed = 0
                eHum.JumpPower = 0
                eHrp.Size = Vector3.new(10, 10, 10)
                eHrp.Velocity = Vector3.new(0, -0.01, 0) 
                eHrp.RotVelocity = Vector3.new(0, 0.01, 0)

                if useV1 then eHrp.CFrame = hrp.CFrame * CFrame.new(0, 12, 0)
                elseif useV2 and autoLevelFarmEnabled then eHrp.CFrame = hrp.CFrame * CFrame.new(0, -25, 0) end
                
                pcall(function() eHum:UnequipTools() end)
            end
        end
    end
end

