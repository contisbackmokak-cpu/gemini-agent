-- uçuş fonksiyonu
local function ucusa_gec(hedef_pos)
    local char = oyuncu.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    ayarlar.uculuyor = true
    
    local mesafe = (hrp.Position - hedef_pos).Magnitude
    local hiz = mesafe / 300 -- saniyede 300 stud
    
    local tween_ayari = TweenInfo.new(hiz, Enum.EasingStyle.Linear)
    local ucus = tweenservice:Create(hrp, tween_ayari, {CFrame = CFrame.new(hedef_pos)})
    
    -- yerçekimi bozmasın diye havada tutma
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Parent = hrp
    
    ucus:Play()
    ucus.Completed:Wait()
    
    if bv then bv:Destroy() end
    ayarlar.uculuyor = false
end

